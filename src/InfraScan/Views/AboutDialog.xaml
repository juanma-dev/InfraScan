<Window x:Class="InfraScan.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca de InfraScan" Height="520" Width="460"
        Icon="pack://application:,,,/Resources/icon.ico"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgDarkBrush}" ShowInTaskbar="False">

    <Grid>
        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28">

                <!-- Logo -->
                <Border Background="{StaticResource AccentRedBrush}" CornerRadius="16" 
                        Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="🛡️" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- App Name -->
                <TextBlock Text="InfraScan" FontSize="28" FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="v1.0.0" FontSize="13" Foreground="{StaticResource TextMutedBrush}" 
                           HorizontalAlignment="Center" Margin="0,2,0,20"/>

                <!-- Description -->
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20">
                    Herramienta profesional para el monitoreo de servidores Linux
                    mediante SSH. Genera informes detallados en formato .docx
                    con datos de rendimiento, seguridad y estado del sistema.
                </TextBlock>

                <!-- Separator -->
                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

                <!-- Credits -->
                <TextBlock Text="Hecho por" FontSize="11" Foreground="{StaticResource TextMutedBrush}" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Juanma" FontSize="18" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,4,0,16">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource AccentRed}" Offset="0"/>
                            <GradientStop Color="{StaticResource AccentGold}" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- Copyright -->
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12">
                    Copyright © 2026 Juanma. Todos los derechos reservados.
                </TextBlock>

                <!-- License -->
                <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="📜 Licencia" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                            Este programa es software libre: puede redistribuirlo y/o
                            modificarlo bajo los términos de la Licencia Pública General
                            GNU (GNU General Public License) versión 3, publicada por
                            la Free Software Foundation.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- GitHub -->
                <Button Style="{StaticResource SecondaryButton}" Click="OpenGitHub_Click"
                        HorizontalAlignment="Center" Padding="16,8" Margin="0,0,0,16">
                    <TextBlock>
                        <Run Text="🔗 " FontSize="14"/>
                        <Run Text="github.com/juanma-dev/InfraScan" Foreground="{StaticResource AccentBlueBrush}"/>
                    </TextBlock>
                </Button>

                <!-- Close -->
                <Button Content="Cerrar" Style="{StaticResource PrimaryButton}" 
                        Click="Close_Click" HorizontalAlignment="Center" Padding="24,10"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
