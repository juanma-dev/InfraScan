<Window x:Class="InfraScan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:InfraScan.Converters"
        Title="InfraScan - Monitoreo de Servidores" 
        Icon="pack://application:,,,/Resources/icon.ico"
        Height="720" Width="1100" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- === HEADER BAR === -->
        <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="InfraScan" FontSize="18" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Monitoreo de Servidores Linux" FontSize="10" 
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Menu Button -->
                <Button Grid.Column="2" Style="{StaticResource IconButton}" 
                        x:Name="MenuButton" Click="MenuButton_Click"
                        ToolTip="Menú" Width="40" Height="40">
                    <TextBlock Text="☰" FontSize="20" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="MainMenu" Style="{StaticResource ModernContextMenu}">
                            <MenuItem Header="➕  Agregar servidor" Click="AddServer_Click"/>
                            <MenuItem Header="📂  Abrir servidor" Click="OpenServer_Click"/>
                            <Separator/>
                            <MenuItem Header="⚙️  Configuración" Click="Config_Click"/>
                            <Separator/>
                            <MenuItem Header="ℹ️  About" Click="About_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Border>

        <!-- === MAIN CONTENT === -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- === LEFT PANEL: Servers List === -->
            <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Panel Header -->
                    <Border Grid.Row="0" Padding="16,14" 
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="SERVIDORES" FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </Border>

                    <!-- Server List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl x:Name="ServerList" ItemsSource="{Binding Servers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="ServerCard" Background="{StaticResource BgCardBrush}" 
                                            CornerRadius="8" Margin="0,4" Padding="12,10" Cursor="Hand"
                                            MouseLeftButtonDown="ServerCard_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="{Binding DisplayName}" 
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Row="1" Text="{Binding Host}" 
                                                       FontSize="11" Foreground="{StaticResource TextMutedBrush}" 
                                                       Margin="0,2,0,6"/>

                                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="🗑️" Style="{StaticResource IconButton}" 
                                                        ToolTip="Eliminar servidor" Margin="0,0,6,0"
                                                        Tag="{Binding Id}" Click="DeleteServer_Click"/>
                                                <Button Content="✏️ Editar" Style="{StaticResource SecondaryButton}" 
                                                        Padding="10,4" FontSize="11" Margin="0,0,6,0"
                                                        Tag="{Binding Id}" Click="EditServer_Click"/>
                                                <Button Content="📄 Generar" Style="{StaticResource PrimaryButton}" 
                                                        Padding="10,4" FontSize="11"
                                                        Tag="{Binding Id}" Click="GenerateReport_Click"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Add Button -->
                    <Border Grid.Row="2" Padding="12" 
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Button Style="{StaticResource GoldButton}" Click="AddServer_Click"
                                Padding="0,10" FontSize="14">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Agregar Servidor" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Grid.Column="1" Background="{StaticResource BorderBrush}"/>

            <!-- === RIGHT PANEL: Console Output === -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Console Header -->
                <Border Grid.Row="0" Padding="16,10" 
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Background="{StaticResource BgMediumBrush}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreenBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="CONSOLA" FontSize="11" FontWeight="Bold" 
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                        <Button Content="🗑️ Limpiar" Style="{StaticResource SecondaryButton}" 
                                HorizontalAlignment="Right" Padding="10,4" FontSize="11"
                                Click="ClearConsole_Click"/>
                    </Grid>
                </Border>

                <!-- Console Content -->
                <Border Grid.Row="1" Background="#0D1117" Padding="0">
                    <ScrollViewer x:Name="ConsoleScroller" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="ConsoleTextBox" 
                                 Text="{Binding ConsoleOutput, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 Background="Transparent"
                                 Foreground="#C9D1D9"
                                 FontFamily="Consolas, Courier New"
                                 FontSize="12.5"
                                 BorderThickness="0"
                                 Padding="16,12"
                                 VerticalScrollBarVisibility="Disabled"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- === STATUS BAR === -->
        <Border Grid.Row="2" Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusText}" 
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" Text="InfraScan v1.0 | GPL v3" 
                           Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                <ProgressBar Grid.Column="2" Value="{Binding Progress}" 
                             Maximum="100" Height="4" VerticalAlignment="Center"
                             Background="{StaticResource BgCardBrush}"
                             Foreground="{StaticResource AccentRedBrush}"
                             Visibility="{Binding IsWorking, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
