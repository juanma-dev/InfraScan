<Window x:Class="InfraScan.Views.ServerBrowserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Servidores Guardados" Height="480" Width="600"
        Icon="pack://application:,,,/Resources/icon.ico"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}" ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}" Padding="20,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="📂 Servidores Existentes" FontSize="18" FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimaryBrush}"/>
        </Border>

        <!-- Server List -->
        <ScrollViewer Grid.Row="1" Padding="16">
            <ItemsControl x:Name="ServersList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" 
                                Padding="16,12" Margin="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0">
                                        <Run Text="{Binding Host, Mode=OneWay}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding StatusDisplay, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="✏️ Editar" Style="{StaticResource SecondaryButton}" 
                                            Padding="10,6" FontSize="12" Margin="0,0,6,0"
                                            Tag="{Binding Id}" Click="Edit_Click"/>
                                    <Button Content="📄 Generar" Style="{StaticResource PrimaryButton}" 
                                            Padding="10,6" FontSize="12"
                                            Tag="{Binding Id}" Click="Generate_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Close -->
        <Border Grid.Row="2" Padding="20,12" Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Button Content="Cerrar" Style="{StaticResource SecondaryButton}" 
                    Click="Close_Click" HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Window>
