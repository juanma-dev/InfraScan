<Window x:Class="InfraScan.Views.MonitoringDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:InfraScan.Controls"
        xmlns:conv="clr-namespace:InfraScan.Converters"
        Title="InfraScan — Panel de Monitoreo"
        Height="780" Width="1280" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        FontFamily="Segoe UI">

    <Window.Resources>
        <conv:ColorToBrushConverter             x:Key="ColorToBrush"/>
        <conv:BoolToOpacityConverter            x:Key="BoolToOpacity"/>
        <conv:BoolToVisibilityConverter         x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter  x:Key="InvBoolToVis"/>
        <conv:BoolToSpinnerVisibilityConverter  x:Key="SpinnerVis"/>
        <conv:CountToVisibilityConverter        x:Key="CountToVis"/>
        <conv:CountToInverseVisibilityConverter x:Key="CountToInvVis"/>

        <!-- Dark ComboBox style matching theme -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#0D1525"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Cursor="Hand"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <ContentPresenter x:Name="cp" Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"/>
                                                <TextBlock Text=" ▾" Foreground="#374151" VerticalAlignment="Center" FontSize="10"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Fade" PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom">
                                <Border Background="#0D1525" BorderBrush="#1E2D45" BorderThickness="1"
                                        CornerRadius="8" Padding="4">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#94A3B8"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="12,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#1A2540"/>
                                            <Setter Property="Foreground" Value="#F1F5F9"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#1E3A5F"/>
                                            <Setter Property="Foreground" Value="#60A5FA"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ProgressBar style for metric bars -->
        <Style x:Key="MetricBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="5"/>
            <Setter Property="Background" Value="#111D30"/>
            <Setter Property="Foreground" Value="#22C55E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track" CornerRadius="3"/>
                            <Border x:Name="PART_Indicator" CornerRadius="3"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- ══════════ HEADER ══════════ -->
        <Border Grid.Row="0" Background="#080D16" BorderBrush="#1A2540" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#111D30" BorderBrush="#1E2D45" BorderThickness="1"
                            CornerRadius="10" Padding="10" Margin="0,0,14,0">
                        <TextBlock Text="📡" FontSize="20"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Panel de Monitoreo" FontSize="18" FontWeight="Bold" Foreground="#F1F5F9"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0" Fill="#22C55E"/>
                            <TextBlock Text="{Binding CountdownDisplay}" FontSize="11" Foreground="#4B5563"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Filter: Todos (dual-dot icon = all servers) -->
                    <Button Click="FilterAll_Click" Cursor="Hand" Margin="0,0,6,0" ToolTip="Mostrar todos">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="20" Padding="12,6" BorderThickness="1"
                                        Background="#111D30" BorderBrush="#1E2D45">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Stacked green+red dots —— represents ALL -->
                                        <Grid Width="16" Height="16" Margin="0,0,7,0">
                                            <Ellipse Width="10" Height="10" Fill="#22C55E"
                                                     HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                            <Ellipse Width="10" Height="10" Fill="#EF4444"
                                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                     Opacity="0.9"/>
                                        </Grid>
                                        <TextBlock Text="Todos" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFilterAll}" Value="True">
                                                            <Setter Property="Foreground" Value="#F1F5F9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterAll}" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#152035"/>
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#2D4A6A"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#1A2D4A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Filter: Online -->
                    <Button Click="FilterOnline_Click" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="20" Padding="14,5" BorderThickness="1"
                                        Background="#071A0F" BorderBrush="#14532D">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="#22C55E"
                                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Foreground="#22C55E" FontSize="12" FontWeight="SemiBold">
                                            <Run Text="{Binding OnlineCount, Mode=OneWay}"/><Run Text=" online"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterOnline}" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#22C55E"/>
                                        <Setter TargetName="bd" Property="Background" Value="#0D3320"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#0D2B1A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Filter: Offline -->
                    <Button Click="FilterOffline_Click" Cursor="Hand" Margin="0,0,20,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="20" Padding="14,5" BorderThickness="1"
                                        Background="#1A0707" BorderBrush="#7F1D1D">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="#EF4444"
                                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Foreground="#EF4444" FontSize="12" FontWeight="SemiBold">
                                            <Run Text="{Binding OfflineCount, Mode=OneWay}"/><Run Text=" offline"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterOffline}" Value="True">
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#EF4444"/>
                                        <Setter TargetName="bd" Property="Background" Value="#2B0A0A"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#260A0A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Interval selector —— fully dark themed -->
                    <Border Background="#080D16" BorderBrush="#1A2540" BorderThickness="1"
                            CornerRadius="20" Padding="12,5" Margin="0,0,16,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏱" FontSize="12" VerticalAlignment="Center"
                                       Foreground="#3B82F6" Margin="0,0,7,0"/>
                            <ComboBox x:Name="IntervalCombo"
                                      Style="{StaticResource DarkCombo}"
                                      VerticalAlignment="Center"
                                      SelectionChanged="IntervalCombo_SelectionChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- Search box —— lupa izquierda, texto derecha -->
                    <Border Background="#080D16" BorderBrush="#1A2540" BorderThickness="1"
                            CornerRadius="20" Width="230">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                            </Grid.ColumnDefinitions>
                            <!-- Lupa icon left -->
                            <Border Grid.Column="0" Background="#0D1A2E"
                                    CornerRadius="20,0,0,20">
                                <Path Data="M 6,6 A 4,4 0 1 1 6,6.01 M 9.2,9.2 L 13,13"
                                      Stroke="#3B82F6" StrokeThickness="1.8"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="16" Height="16" Stretch="Uniform"/>
                            </Border>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#CBD5E1" CaretBrush="#3B82F6"
                                     FontSize="12.5" Padding="0,10"
                                     VerticalAlignment="Center"
                                     SelectionBrush="#1E3A5F"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <Button Grid.Column="2" Click="RefreshButton_Click"
                        IsEnabled="{Binding IsNotRefreshing}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#111D30" BorderBrush="#1E2D45"
                                    BorderThickness="1" CornerRadius="8" Padding="16,9">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↻" FontSize="16" Margin="0,0,7,0"
                                               VerticalAlignment="Center" Foreground="#94A3B8"/>
                                    <TextBlock Text="Actualizar" VerticalAlignment="Center"
                                               FontSize="13" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1A2D4A"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ══════════ MAIN CONTENT ══════════ -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding FilteredMetrics.Count, Converter={StaticResource CountToInvVis}}">
                <TextBlock Text="📡" FontSize="60" HorizontalAlignment="Center"
                           Margin="0,0,0,20" Opacity="0.2"/>
                <TextBlock Text="Sin servidores configurados" FontSize="18"
                           Foreground="#2D3748" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Server cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,12,10,0"
                          Visibility="{Binding FilteredMetrics.Count, Converter={StaticResource CountToVis}}">
                <ItemsControl ItemsSource="{Binding FilteredMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- SERVER CARD -->
                            <Border Margin="8" Padding="20,18" Width="320"
                                    CornerRadius="14" BorderThickness="1"
                                    Opacity="{Binding IsOnline, Converter={StaticResource BoolToOpacity}}"
                                    Background="#0F1825"
                                    BorderBrush="#1E2D45">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="16"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Header -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding ServerName}"
                                                       FontSize="15" FontWeight="Bold" Foreground="#F1F5F9"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Host}" FontSize="11"
                                                       Foreground="#374151"
                                                       FontFamily="Consolas, Courier New"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>

                                        <!-- Status badge + spinner -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                            <!-- Spinner -->
                                            <TextBlock Text="⟳" FontSize="16" Foreground="#3B82F6"
                                                       Margin="0,2,8,0"
                                                       Visibility="{Binding IsRefreshing, Converter={StaticResource SpinnerVis}}">
                                                <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                                <TextBlock.RenderTransform><RotateTransform/></TextBlock.RenderTransform>
                                                <TextBlock.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                                                    From="0" To="360" Duration="0:0:1"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </TextBlock.Triggers>
                                            </TextBlock>

                                            <!-- Online/Offline text badge -->
                                            <Border CornerRadius="20" Padding="10,4" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#0D2B1A"/>
                                                        <Setter Property="BorderBrush" Value="#14532D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                <Setter Property="Background" Value="#1A0707"/>
                                                                <Setter Property="BorderBrush" Value="#7F1D1D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#22C55E"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                        <Setter Property="Fill" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock FontSize="10" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="ONLINE"/>
                                                                <Setter Property="Foreground" Value="#22C55E"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                        <Setter Property="Text" Value="OFFLINE"/>
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Row 2: Gauges (online) / Error (offline) -->
                                    <Grid Grid.Row="2" Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:CircularGauge Grid.Column="0"
                                            Value="{Binding CpuPercent, Mode=OneWay}"
                                            GaugeColor="{Binding CpuColor, Mode=OneWay}"
                                            LabelText="CPU"
                                            DisplayText="{Binding CpuDisplay, Mode=OneWay}"
                                            HorizontalAlignment="Center"/>
                                        <controls:CircularGauge Grid.Column="1"
                                            Value="{Binding RamPercent, Mode=OneWay}"
                                            GaugeColor="{Binding RamColor, Mode=OneWay}"
                                            LabelText="RAM"
                                            DisplayText="{Binding RamGaugeText, Mode=OneWay}"
                                            HorizontalAlignment="Center"/>
                                        <controls:CircularGauge Grid.Column="2"
                                            Value="{Binding DiskPercent, Mode=OneWay}"
                                            GaugeColor="{Binding DiskColor, Mode=OneWay}"
                                            LabelText="DISCO"
                                            DisplayText="{Binding DiskGaugeText, Mode=OneWay}"
                                            HorizontalAlignment="Center"/>
                                    </Grid>

                                    <!-- Sub-labels below gauges: RAM and Disk GB detail -->
                                    <Grid Grid.Row="2" VerticalAlignment="Bottom"
                                          Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="{Binding RamSubLabel, Mode=OneWay}"
                                                   FontSize="9" Foreground="#374151"
                                                   HorizontalAlignment="Center" Margin="0,90,0,0"/>
                                        <TextBlock Grid.Column="2" Text="{Binding DiskSubLabel, Mode=OneWay}"
                                                   FontSize="9" Foreground="#374151"
                                                   HorizontalAlignment="Center" Margin="0,90,0,0"/>
                                    </Grid>

                                    <Border Grid.Row="2" Background="#0F0505" CornerRadius="10"
                                            Padding="14,12" BorderBrush="#3B0000" BorderThickness="1"
                                            Visibility="{Binding IsOnline, Converter={StaticResource InvBoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="⚠  Sin conexión" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#F87171" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding ErrorMessage}" FontSize="11"
                                                       Foreground="#7C2D12" TextWrapping="Wrap"
                                                       FontFamily="Consolas, Courier New"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Separator -->
                                    <Border Grid.Row="3" Height="1" Background="#1A2540" VerticalAlignment="Center"/>

                                    <!-- Row 4: Progress bars -->
                                    <StackPanel Grid.Row="4"
                                                Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="RAM" FontSize="9.5" Foreground="#374151" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding RamDisplay}" FontSize="9.5" Foreground="#374151"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding RamPercent, Mode=OneWay}" Style="{StaticResource MetricBar}"
                                                     Foreground="{Binding RamColor, Converter={StaticResource ColorToBrush}}"
                                                     Margin="0,0,0,10"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="DISCO" FontSize="9.5" Foreground="#374151" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DiskDisplay}" FontSize="9.5" Foreground="#374151"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding DiskPercent, Mode=OneWay}" Style="{StaticResource MetricBar}"
                                                     Foreground="{Binding DiskColor, Converter={StaticResource ColorToBrush}}"/>
                                    </StackPanel>

                                    <!-- Separator -->
                                    <Border Grid.Row="5" Height="1" Background="#1A2540" VerticalAlignment="Center"/>

                                    <!-- Row 6: Uptime + Load -->
                                    <Grid Grid.Row="6"
                                          Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="⏱ UPTIME" FontSize="9" Foreground="#2D3A50" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Uptime}" FontSize="11"
                                                       Foreground="#64748B" Margin="0,3,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontFamily="Consolas, Courier New"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="⚖ CARGA (1·5·15)" FontSize="9" Foreground="#2D3A50" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding LoadDisplay}" FontSize="11"
                                                       Foreground="#64748B" Margin="0,3,0,0"
                                                       FontFamily="Consolas, Courier New"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Separator -->
                                    <Border Grid.Row="7" Height="1" Background="#1A2540" VerticalAlignment="Center"/>

                                    <!-- Row 8: Connections / Temp / Processes pills -->
                                    <Grid Grid.Row="8"
                                          Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#0A1525" CornerRadius="8"
                                                Padding="8,7" Margin="0,0,4,0">
                                            <StackPanel>
                                                <TextBlock Text="🌐" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding ActiveConnections}"
                                                           FontSize="14" FontWeight="Bold" Foreground="#60A5FA"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                <TextBlock Text="conex." FontSize="9" Foreground="#2D3A50"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="#0A1525" CornerRadius="8"
                                                Padding="8,7" Margin="4,0">
                                            <StackPanel>
                                                <TextBlock Text="🌡" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding TempDisplay}"
                                                           FontSize="14" FontWeight="Bold" Foreground="#FB923C"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                <TextBlock Text="temp." FontSize="9" Foreground="#2D3A50"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2" Background="#0A1525" CornerRadius="8"
                                                Padding="8,7" Margin="4,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="⚙" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding ProcessCount}"
                                                           FontSize="14" FontWeight="Bold" Foreground="#A78BFA"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                <TextBlock Text="procesos" FontSize="9" Foreground="#2D3A50"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Timestamp (tooltip) -->
                                    <TextBlock Grid.Row="8" Text="{Binding LastUpdatedDisplay}"
                                               FontSize="9" Foreground="#1F2937"
                                               HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                               Margin="0,6,0,-4"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══════════ STATUS BAR ══════════ -->
        <Border Grid.Row="2" Background="#080D16" BorderBrush="#1A2540" BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <TextBlock Text="{Binding StatusText, Mode=OneWay}" Foreground="#2D3A50"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CountdownDisplay, Mode=OneWay}" Foreground="#1A2540"
                           FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
