<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Dark Theme Colors -->
    <Color x:Key="BgDark">#1A1A2E</Color>
    <Color x:Key="BgMedium">#16213E</Color>
    <Color x:Key="BgCard">#1F2B47</Color>
    <Color x:Key="BgHover">#2A3A5C</Color>
    <Color x:Key="BgInput">#0F1729</Color>

    <!-- Accent Colors (Universidad de Pamplona inspired: red/gold) -->
    <Color x:Key="AccentRed">#AD3333</Color>
    <Color x:Key="AccentRedLight">#D44444</Color>
    <Color x:Key="AccentGold">#C9A74E</Color>
    <Color x:Key="AccentGoldLight">#E0C068</Color>
    <Color x:Key="AccentBlue">#3B82F6</Color>
    <Color x:Key="AccentGreen">#22C55E</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#F1F5F9</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color>
    <Color x:Key="TextMuted">#64748B</Color>
    <Color x:Key="TextWhite">#FFFFFF</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#2D3A56</Color>
    <Color x:Key="BorderLight">#3D4A66</Color>

    <!-- Status Colors -->
    <Color x:Key="StatusSuccess">#22C55E</Color>
    <Color x:Key="StatusWarning">#F59E0B</Color>
    <Color x:Key="StatusError">#EF4444</Color>
    <Color x:Key="StatusInfo">#3B82F6</Color>

    <!-- SolidColorBrushes -->
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgMediumBrush" Color="{StaticResource BgMedium}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}"/>
    <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInput}"/>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="AccentRedLightBrush" Color="{StaticResource AccentRedLight}"/>
    <SolidColorBrush x:Key="AccentGoldBrush" Color="{StaticResource AccentGold}"/>
    <SolidColorBrush x:Key="AccentGoldLightBrush" Color="{StaticResource AccentGoldLight}"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="TextWhiteBrush" Color="{StaticResource TextWhite}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLight}"/>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentRed}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentGold}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1A1A2E" Offset="0"/>
        <GradientStop Color="#16213E" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
